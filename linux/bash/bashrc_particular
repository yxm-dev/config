# Vim ALIASES
## "config" function to open config files
    function config(){
        config_dir=~/files/config/
        declare -a config_dirs
        if [[ -z "$1" ]]; then
            vim $config_dir
        elif [[ -n $1 ]] && [[ -z $2 ]]; then
            vim $config_dir/$1
        elif [[ -n $1 ]] && [[ -n $2 ]]; then
            vim $config_dir/$1/$2
        else
            echo "There is no such kind of config."
        fi
    }
    alias cfg="config"
    alias c="config"

