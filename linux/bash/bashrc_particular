## "cv" function to open curriculum files
    function cv(){
        cv_dir=$HOME/files/nerd/cv
        if [[ -z "$1" ]]; then
            vim $cv_dir
        elif [[ "$1" = "res" ]] || [[ "$1" = "-r" ]]; then
            vim $cv_dir/yxm-cv.md
        elif [[ "$1" = "dev" ]] || [[ "$1" = "-d" ]]; then
            if [[ "$2" == "pt" ]] || [[ "$2" == "-pt" ]]; then
                vim $cv_dir/yxm-dev-pt.md
            elif [[ "$2" == "en" ]] || [[ "$2" == "-en" ]]; then
                vim $cv_dir/yxm-dev-en.md
            else
                echo "option not defined."
            fi
        else
            echo -e -n "
Try \"cv option argument\" 

* option = -r, res; -d, -dev
* argument = -pt, pt; -en, en.

"
        fi
    }
